# ─── Meta World 환경변수 ───
# 이 파일을 복사해서 .env 로 만들고 값을 채우세요. (.env 는 git에 올라가지 않습니다)

# MongoDB Atlas 연결 문자열
# Atlas → Database → Connect → Drivers 에서 복사. <password> 와 DB 이름을 채우세요.
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/metaworld?retryWrites=true&w=majority

# JWT 서명 비밀키 — 길고 랜덤하게. 아래 명령으로 생성 가능:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=여기에_긴_랜덤_문자열

# 포트 (Render가 자동 주입하므로 로컬에서만 의미 있음)
PORT=3000
